# Copy to .env for local development. Never commit .env.

# FantasyPros public API key (https://www.fantasypros.com/apis/)
FANTASYPROS_API_KEY=

# BettingPros API credentials (partner key + account credentials)
BP_PARTNER_KEY=
BP_USER=
BP_USER_KEY=

# Password for the dashboard gate. Pick something long and random.
APP_PASSWORD=
